# Neon pooled connection string (same DB as the web app).
# Format: postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://user:password@ep-xyz-pooler.us-east-2.aws.neon.tech/phas?sslmode=require&pgbouncer=true&connection_limit=1

# How often the HTTP prober runs (cron expression, default: every 5 minutes).
PROBE_CRON=*/5 * * * *

# ── Signal fusion thresholds (v1 — tune with real data) ──────────────────────
FUSION_OPEN_PROBE_FAILURES=2
FUSION_OPEN_AFFECTED_RATIO=0.30
FUSION_OPEN_MIN_REPORTERS=5
FUSION_OPEN_WINDOW_HOURS=2
FUSION_CLOSE_PROBE_PASSES=3
FUSION_CLOSE_RATIO_THRESHOLD=0.10
FUSION_RECUR_WINDOW_DAYS=7

# FCM server key for push notifications (Phase 1: leave blank to log only).
FCM_SERVER_KEY=

# Optional: expose a lightweight HTTP server for the /internal/fusion/:id trigger.
INTERNAL_PORT=3001
