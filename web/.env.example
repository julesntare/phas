# Copy to .env.local for local dev.

# ── Database (Neon) ───────────────────────────────────────────────────────────
# Use the POOLED connection string from the Neon dashboard for Vercel.
# Format: postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# Add &pgbouncer=true&connection_limit=1 to the pooled URL.
DATABASE_URL=postgresql://user:password@ep-xyz-pooler.us-east-2.aws.neon.tech/phas?sslmode=require&pgbouncer=true&connection_limit=1

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_me_with_32_random_bytes
JWT_EXPIRY_SECONDS=86400

# ── Cron ──────────────────────────────────────────────────────────────────────
# Vercel sets this automatically and sends it as Authorization: Bearer <secret>
# on every cron invocation. Also add it to cron-job.org if using external cron.
# Generate with: openssl rand -base64 32
#
# NOTE: Vercel Hobby plan only supports daily cron frequency. For 5-minute
# probing on the free tier, use cron-job.org (free) pointed at:
#   GET https://<your-app>.vercel.app/api/cron/probe
#   Header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace_me_with_32_random_bytes

# ── Vercel Blob (image uploads) ──────────────────────────────────────────────
# Auto-set by Vercel when you enable Blob storage (dashboard → Storage → Blob).
# For local dev: copy the token from Vercel project settings → Environment Variables.
BLOB_READ_WRITE_TOKEN=

# ── Email — Resend ────────────────────────────────────────────────────────────
# Sign up at resend.com, verify your sending domain, and paste the API key here.
# When unset (local dev), setup codes are logged to the console instead.
RESEND_API_KEY=
# The "from" address shown on setup emails (must match your verified Resend domain).
EMAIL_FROM=PHAS <noreply@phas.rw>
# In dev, redirect all outgoing emails here instead of the real recipient.
# Useful when using onboarding@resend.dev which only delivers to the account owner.
# Leave unset in production.
DEV_EMAIL_OVERRIDE=
# Full public URL of the app — used in email links.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── SMS — Africa's Talking (recommended for Rwanda) ───────────────────────────
# Leave blank in dev; OTPs are logged to console when AT_API_KEY is unset.
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=PHAS

# ── Signal fusion thresholds (v1 defaults — tune with real data) ──────────────
FUSION_OPEN_PROBE_FAILURES=2
FUSION_OPEN_AFFECTED_RATIO=0.30
FUSION_OPEN_MIN_REPORTERS=5
FUSION_OPEN_WINDOW_HOURS=2
FUSION_CLOSE_PROBE_PASSES=3
FUSION_CLOSE_RATIO_THRESHOLD=0.10
FUSION_RECUR_WINDOW_DAYS=7
